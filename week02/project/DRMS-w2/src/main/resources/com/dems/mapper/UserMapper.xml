<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dems.mapper.UserMapper">
    <insert id="insertUser">
            insert into user(user_id,username,password,role,create_time,update_time)
            values(#{userId},#{username},#{password},#{role},#{createTime},#{updateTime})
    </insert>
    <update id="updateBindById">
            update user set building_id=#{buildingId},room_id=#{roomId},update_time=#{updateTime}
            where user_id=#{userId}
    </update>
    <update id="updatePassById">
            update user set password=#{password},update_time=#{updateTime}
            where user_id=#{userId}
    </update>

    <select id="selectUserByIdPass" resultType="com.dems.pojo.User">
        select * from user where user_id=#{userId} and password=#{password}
    </select>
    <select id="selectUserById" resultType="com.dems.pojo.User">
        select * from user where user_id=#{userId}
    </select>
</mapper>